{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RNT56/agentic-flows/docs/proposals/schemas/node.schema.v1_1.json",
  "title": "Agentic Flow Node (v1.1 proposal)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "description"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "type": {
      "enum": [
        "intake",
        "plan",
        "agent_task",
        "tool",
        "verifier",
        "approval",
        "decision",
        "handoff",
        "finalizer",
        "flow_ref"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "agent": {
      "type": "string"
    },
    "tool": {
      "type": "string"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "requires": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "produces": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": true
    },
    "ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "flow_id"
      ],
      "properties": {
        "flow_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/\\-]*[a-z0-9]$"
        },
        "version_constraint": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "with": {
      "type": "object",
      "additionalProperties": true
    },
    "expose": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provides": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ephemeral": {
          "type": "boolean"
        },
        "teardown_required": {
          "type": "boolean"
        }
      }
    },
    "iteration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "until": {
          "type": "string"
        },
        "on_exhausted": {
          "enum": [
            "fail",
            "handoff"
          ]
        }
      }
    },
    "fan_out": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "over": {
          "type": "string"
        },
        "cardinality": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 1
            },
            "max": {
              "type": "integer"
            }
          }
        },
        "aggregate": {
          "enum": [
            "all_pass",
            "threshold",
            "any"
          ]
        },
        "instance_id": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "flow_ref"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "ref",
          "expose"
        ]
      }
    },
    {
      "if": {
        "not": {
          "properties": {
            "type": {
              "const": "flow_ref"
            }
          }
        }
      },
      "then": {
        "properties": {
          "ref": false,
          "with": false,
          "expose": false
        }
      }
    }
  ]
}