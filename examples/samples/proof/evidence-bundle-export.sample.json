{
  "sample_version": "agentic-flows.sample/v1",
  "flow": {
    "id": "proof.evidence-bundle-export",
    "version": "0.1.0",
    "source": "flows/proof/evidence-bundle-export/flow.yaml"
  },
  "inputs": {
    "run_bundle": "file://examples/runs/feature-implementation.run.json",
    "verifier_outcome": {
