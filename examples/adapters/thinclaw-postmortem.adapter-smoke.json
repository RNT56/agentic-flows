{
  "adapter_smoke_version": "agentic-flows.adapter-smoke/v1",
  "consumer": "thinclaw",
  "flow": {
    "id": "docs.postmortem",
    "version": "0.1.0",
    "source": "flows/docs/postmortem/flow.yaml"
  },
  "capability_support": [
    "timeline.assemble",
    "evidence.capture"
  ],
  "node_type_mappings": {
    "intake": "incident intake",
    "agent_task": "timeline and cause analyst",
    "verifier": "completeness verifier",
    "finalizer": "postmortem closeout"
  },
  "run_bundle": "runs/thinclaw-postmortem.run.json",
  "negative_run_bundle": {
    "source": "../../tests/fixtures/invalid-run-missing-gate.json",
    "expected_error": "required quality gate"
  },
  "notes": "Repo-local contract smoke for a possible ThinClaw postmortem adapter."
}
