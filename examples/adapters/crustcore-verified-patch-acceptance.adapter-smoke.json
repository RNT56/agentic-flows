{
  "adapter_smoke_version": "agentic-flows.adapter-smoke/v1",
  "consumer": "crustcore",
  "flow": {
    "id": "proof.verified-patch-acceptance",
    "version": "0.1.0",
    "source": "flows/proof/verified-patch-acceptance/flow.yaml"
  },
  "capability_support": [
    "patch.inspect",
    "command.run",
    "evidence.capture",
    "completion.verify"
  ],
  "node_type_mappings": {
    "intake": "acceptance request intake",
    "tool": "verifier check runner",
    "verifier": "gate evidence collector",
    "decision": "accept-or-fail-closed decision",
    "finalizer": "verified acceptance closeout"
  },
  "run_bundle": "runs/crustcore-verified-patch-acceptance.run.json",
  "negative_run_bundle": {
    "source": "../../tests/fixtures/invalid-run-missing-gate.json",
    "expected_error": "required quality gate"
  },
  "notes": "Repo-local contract smoke for a possible CrustCore verified-acceptance adapter."
}
