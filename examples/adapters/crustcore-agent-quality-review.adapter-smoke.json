{
  "adapter_smoke_version": "agentic-flows.adapter-smoke/v1",
  "consumer": "crustcore",
  "flow": {
    "id": "orchestration.agent-quality-review",
    "version": "0.1.0",
    "source": "flows/orchestration/agent-quality-review/flow.yaml"
  },
  "capability_support": [
    "work.read",
    "claim.verify",
    "evidence.capture"
  ],
  "node_type_mappings": {
    "intake": "agent work intake",
    "agent_task": "claim checker",
    "verifier": "findings verifier",
    "finalizer": "quality review closeout"
  },
  "run_bundle": "runs/crustcore-agent-quality-review.run.json",
  "negative_run_bundle": {
    "source": "../../tests/fixtures/invalid-run-missing-gate.json",
    "expected_error": "required quality gate"
  },
  "notes": "Repo-local contract smoke for a possible CrustCore agent-quality-review adapter."
}
