{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RNT56/agentic-flows/schemas/node.schema.json",
  "title": "Agentic Flow Node",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "description"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "type": {
      "enum": [
        "intake",
        "plan",
        "agent_task",
        "tool",
        "verifier",
        "approval",
        "decision",
        "handoff",
        "finalizer",
        "flow_ref"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "instructions": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "type": { "enum": ["text", "markdown", "json", "patch", "command", "uri", "boolean", "number"] },
          "required": { "type": "boolean" },
          "default": {},
          "description": { "type": "string" }
        }
      }
    },
    "inputs_schema": {
      "type": "array",
      "items": { "$ref": "#/$defs/field" }
    },
    "outputs_schema": {
      "type": "array",
      "items": { "$ref": "#/$defs/field" }
    },
    "agent": {
      "type": "string"
    },
    "tool": {
      "type": "string"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "requires": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "produces": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "on_failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action"],
      "properties": {
        "action": { "enum": ["retry", "abort", "escalate", "skip"] },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "fallback_node": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": true
    },
    "ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "flow_id"
      ],
      "properties": {
        "flow_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/\\-]*[a-z0-9]$"
        },
        "version_constraint": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "with": {
      "type": "object",
      "additionalProperties": true
    },
    "expose": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provides": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ephemeral": {
          "type": "boolean"
        },
        "teardown_required": {
          "type": "boolean"
        }
      }
    },
    "iteration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "until": {
          "type": "string"
        },
        "on_exhausted": {
          "enum": [
            "fail",
            "handoff"
          ]
        }
      }
    },
    "fan_out": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "over": {
          "type": "string"
        },
        "cardinality": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 1
            },
            "max": {
              "type": "integer"
            }
          }
        },
        "aggregate": {
          "enum": [
            "all_pass",
            "threshold",
            "any"
          ]
        },
        "instance_id": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "flow_ref"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "required": [
          "ref",
          "expose"
        ]
      }
    },
    {
      "if": {
        "not": {
          "properties": {
            "type": {
              "const": "flow_ref"
            }
          }
        }
      },
      "then": {
        "properties": {
          "ref": false,
          "with": false,
          "expose": false
        }
      }
    }
  ],
  "$defs": {
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "required"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "type": { "enum": ["text", "markdown", "json", "patch", "command", "uri", "boolean", "number"] },
        "required": { "type": "boolean" },
        "description": { "type": "string" }
      }
    }
  }
}
