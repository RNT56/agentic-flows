{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RNT56/agentic-flows/schemas/node.schema.json",
  "title": "Agentic Flow Node",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "title", "description"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "type": {
      "enum": ["intake", "plan", "agent_task", "tool", "verifier", "approval", "decision", "handoff", "finalizer"]
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "agent": {
      "type": "string"
    },
    "tool": {
      "type": "string"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "requires": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "produces": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

