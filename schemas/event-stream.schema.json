{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RNT56/agentic-flows/schemas/event-stream.schema.json",
  "title": "Agentic Flow Event Stream",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_stream_version", "flow", "run", "events"],
  "properties": {
    "event_stream_version": {
      "const": "agentic-flows.event-stream/v1"
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "source"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/\\-]*[a-z0-9]$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "core", "status", "started_at"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 8
        },
        "core": {
          "enum": ["thinclaw", "nilcore", "crustcore", "standalone"]
        },
        "status": {
          "enum": ["completed", "failed", "cancelled", "running"]
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
