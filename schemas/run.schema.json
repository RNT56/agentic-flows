{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RNT56/agentic-flows/schemas/run.schema.json",
  "title": "Agentic Flow Run Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_version",
    "flow",
    "run",
    "events"
  ],
  "properties": {
    "run_version": {
      "enum": [
        "agentic-flows.run/v1",
        "agentic-flows.run/v1.1"
      ]
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/\\-]*[a-z0-9]$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "core",
        "status",
        "started_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 8
        },
        "core": {
          "enum": [
            "thinclaw",
            "nilcore",
            "crustcore",
            "standalone"
          ]
        },
        "status": {
          "enum": [
            "completed",
            "failed",
            "cancelled",
            "running"
          ]
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "uri"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]*$"
          },
          "kind": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._-]*$"
          },
          "uri": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "sub_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node_id",
          "flow",
          "run",
          "uri"
        ],
        "properties": {
          "node_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "flow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "version"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9._/\\-]*[a-z0-9]$"
              },
              "version": {
                "type": "string",
                "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
              }
            }
          },
          "run": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "status"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 8
              },
              "status": {
                "enum": [
                  "completed",
                  "failed",
                  "cancelled",
                  "running"
                ]
              }
            }
          },
          "uri": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    }
  }
}
