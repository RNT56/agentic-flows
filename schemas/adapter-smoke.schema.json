{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RNT56/agentic-flows/schemas/adapter-smoke.schema.json",
  "title": "Agentic Flow Adapter Smoke",
  "type": "object",
  "additionalProperties": false,
  "required": ["adapter_smoke_version", "consumer", "flow", "capability_support", "node_type_mappings", "run_bundle"],
  "properties": {
    "adapter_smoke_version": {
      "const": "agentic-flows.adapter-smoke/v1"
    },
    "consumer": {
      "enum": ["thinclaw", "nilcore", "crustcore"]
    },
    "flow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "source"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/\\-]*[a-z0-9]$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "capability_support": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      }
    },
    "node_type_mappings": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 3
      }
    },
    "run_bundle": {
      "type": "string",
      "minLength": 1
    },
    "event_stream": {
      "type": "string",
      "minLength": 1
    },
    "negative_run_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "expected_error"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "expected_error": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
